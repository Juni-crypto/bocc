{
  "name": "bocc",
  "version": "0.1.0",
  "private": true,
  "description": "Be Our Camera Crew - shared event photo galleries with AI face matching",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "api:dev": "npm run start:dev -w @bocc/api",
    "api:build": "npm run build -w @bocc/api",
    "db:migrate": "npm run prisma:migrate -w @bocc/api",
    "db:generate": "npm run prisma:generate -w @bocc/api",
    "db:studio": "npm run prisma:studio -w @bocc/api",
    "setup": "npm install && npm run db:up && npm run db:generate && npm run db:migrate"
  }
}
