# BOCC production environment.
# Copy to .env.prod and fill in:  cp .env.prod.example .env.prod
# .env.prod is gitignored; never commit real secrets.
#
# Used by:  docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Public origin of the API as reached from a browser. No trailing slash and no
# /api suffix here (the web build appends /api itself). On a cloud VM set this
# to http://<public-ip>:4000 (the Terraform user_data fills it in automatically).
PUBLIC_API_URL=http://localhost:4000

# Secret used to sign API JWTs. Generate a strong one, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ---- Immich AI (optional) ----
# Ship with Immich OFF so the stack comes up before an API key exists. After
# the stack is up, mint a key (UI or scripts/setup-immich.mjs), set it below,
# flip IMMICH_ENABLED=true, and re-run `up -d`. See README / infra/terraform.
IMMICH_ENABLED=false
IMMICH_API_KEY=
IMMICH_VERSION=v1.124.2

# ---- App database (pgvector container) ----
DB_USER=bocc
DB_PASSWORD=bocc
DB_NAME=bocc

# ---- Immich's own database (vectorchord container) ----
# Use only A-Za-z0-9 (no special characters or spaces).
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=immich
IMMICH_DB_DATABASE_NAME=immich
